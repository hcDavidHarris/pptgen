{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pptgen/deck.schema.json",
  "title": "pptgen Deck",
  "description": "Schema for pptgen deck YAML files. All slide types and fields are defined here. This schema mirrors the Pydantic DeckFile model and serves as a portable contract for external tooling, IDE validation, and CI checks.",
  "type": "object",
  "required": ["deck", "slides"],
  "additionalProperties": false,
  "properties": {
    "deck": {
      "$ref": "#/definitions/DeckMetadata"
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/Slide"
      },
      "description": "Ordered list of slides. Must contain at least one slide."
    }
  },
  "definitions": {
    "DeckMetadata": {
      "type": "object",
      "required": ["title", "template", "author"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable presentation title."
        },
        "template": {
          "type": "string",
          "minLength": 1,
          "description": "Registered template ID from templates/registry.yaml."
        },
        "author": {
          "type": "string",
          "minLength": 1,
          "description": "Deck author or authoring team."
        },
        "subtitle": {
          "type": "string",
          "description": "Optional deck subtitle."
        },
        "version": {
          "type": "string",
          "description": "Optional content version. Must be a quoted YAML string (e.g. \"1.0\")."
        },
        "date": {
          "type": "string",
          "description": "Optional date string. ISO format recommended (e.g. 2026-03-22)."
        },
        "status": {
          "type": "string",
          "enum": ["draft", "review", "final"],
          "description": "Optional lifecycle status."
        },
        "description": {
          "type": "string",
          "description": "Optional deck description."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional classification tags."
        }
      }
    },
    "SlideBase": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Optional unique slide identifier. Must be unique across the deck."
        },
        "notes": {
          "type": "string",
          "description": "Optional speaker notes. Not rendered in the slide body."
        },
        "visible": {
          "type": "boolean",
          "default": true,
          "description": "Whether the slide renders. Set to false to skip without deleting."
        }
      }
    },
    "TitleSlide": {
      "allOf": [
        { "$ref": "#/definitions/SlideBase" }
      ],
      "type": "object",
      "required": ["type", "title", "subtitle"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["title"] },
        "title": { "type": "string", "minLength": 1, "description": "Main presentation title." },
        "subtitle": { "type": "string", "minLength": 1, "description": "Subtitle or context line." },
        "id": { "type": "string" },
        "notes": { "type": "string" },
        "visible": { "type": "boolean" }
      }
    },
    "SectionSlide": {
      "allOf": [
        { "$ref": "#/definitions/SlideBase" }
      ],
      "type": "object",
      "required": ["type", "section_title"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["section"] },
        "section_title": { "type": "string", "minLength": 1, "description": "Section heading." },
        "section_subtitle": { "type": "string", "description": "Optional section subtitle." },
        "id": { "type": "string" },
        "notes": { "type": "string" },
        "visible": { "type": "boolean" }
      }
    },
    "BulletsSlide": {
      "allOf": [
        { "$ref": "#/definitions/SlideBase" }
      ],
      "type": "object",
      "required": ["type", "title", "bullets"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["bullets"] },
        "title": { "type": "string", "minLength": 1, "description": "Slide title." },
        "bullets": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Bullet point items. Must contain at least one item. Recommended max: 6."
        },
        "id": { "type": "string" },
        "notes": { "type": "string" },
        "visible": { "type": "boolean" }
      }
    },
    "TwoColumnSlide": {
      "allOf": [
        { "$ref": "#/definitions/SlideBase" }
      ],
      "type": "object",
      "required": ["type", "title", "left_content", "right_content"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["two_column"] },
        "title": { "type": "string", "minLength": 1, "description": "Slide title." },
        "left_content": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Left column items."
        },
        "right_content": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Right column items."
        },
        "id": { "type": "string" },
        "notes": { "type": "string" },
        "visible": { "type": "boolean" }
      }
    },
    "MetricItem": {
      "type": "object",
      "required": ["label", "value"],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40,
          "description": "Metric name. Recommended maximum 40 characters."
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "description": "Metric value. Must be a quoted YAML string (e.g. \"99.9\", not 99.9)."
        },
        "unit": {
          "type": "string",
          "description": "Optional unit string. Concatenated directly onto value with no separator."
        }
      }
    },
    "MetricSummarySlide": {
      "allOf": [
        { "$ref": "#/definitions/SlideBase" }
      ],
      "type": "object",
      "required": ["type", "title", "metrics"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["metric_summary"] },
        "title": { "type": "string", "minLength": 1, "description": "Slide title." },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": { "$ref": "#/definitions/MetricItem" },
          "description": "Metric definitions. Phase 1 contract: maximum 4 metrics per slide."
        },
        "id": { "type": "string" },
        "notes": { "type": "string" },
        "visible": { "type": "boolean" }
      }
    },
    "ImageCaptionSlide": {
      "allOf": [
        { "$ref": "#/definitions/SlideBase" }
      ],
      "type": "object",
      "required": ["type", "title", "image_path", "caption"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["image_caption"] },
        "title": { "type": "string", "minLength": 1, "description": "Slide title." },
        "image_path": { "type": "string", "minLength": 1, "description": "Path to image file relative to working directory." },
        "caption": { "type": "string", "minLength": 1, "description": "Caption text displayed below the image." },
        "id": { "type": "string" },
        "notes": { "type": "string" },
        "visible": { "type": "boolean" }
      }
    },
    "Slide": {
      "oneOf": [
        { "$ref": "#/definitions/TitleSlide" },
        { "$ref": "#/definitions/SectionSlide" },
        { "$ref": "#/definitions/BulletsSlide" },
        { "$ref": "#/definitions/TwoColumnSlide" },
        { "$ref": "#/definitions/MetricSummarySlide" },
        { "$ref": "#/definitions/ImageCaptionSlide" }
      ],
      "discriminator": {
        "propertyName": "type"
      }
    }
  }
}
