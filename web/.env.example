# API base URL for the pptgen FastAPI backend.
# Leave empty to use Vite's dev-server proxy (default for local development).
# Set to an explicit origin for container or reverse-proxy deployments.
#
# Example (container):
#   VITE_API_BASE_URL=http://localhost:8000
#
# Example (remote):
#   VITE_API_BASE_URL=https://api.example.internal
VITE_API_BASE_URL=
